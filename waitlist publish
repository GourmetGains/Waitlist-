  justify-content: center;
  gap: 60px;
  flex-wrap: wrap;
  margin: 0 auto 80px;
  animation: fadeUp 0.6s 0.4s ease both;
}
.stat-item { text-align: center; }
.stat-val {
  font-family: 'Playfair Display', serif;
  font-size: 32px;
  font-weight: 900;
  color: #fff;
  line-height: 1;
  margin-bottom: 5px;
}
.stat-val span { color: var(--brand-light); }
.stat-lbl { font-size: 12px; color: rgba(255,255,255,0.35); font-weight: 400; letter-spacing: 0.05em; }
.divider-line { width: 1px; height: 40px; background: rgba(255,255,255,0.1); align-self: center; }

