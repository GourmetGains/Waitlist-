<script>
  (function() {
    // ── EmailJS Init ──
    // SETUP REQUIRED: Replace these with your own EmailJS credentials.
    // 1. Sign up free at https://www.emailjs.com
    // 2. Create a service (Gmail works) and note your Service ID
    // 3. Create an email template using the template below — note your Template ID
    // 4. Find your Public Key in Account > API Keys
    const EMAILJS_PUBLIC_KEY  = "Y4g53tUGsk-2Pd9kN";
    const EMAILJS_SERVICE_ID  = "service_f5wbpeb";
    const EMAILJS_TEMPLATE_ID = "template_kwpm308";
    // ALSO: Add your notification email in the template so YOU get alerted per signup.

    emailjs.init({ publicKey: EMAILJS_PUBLIC_KEY });

    // ── Scroll Reveals ──
    const revealEls = document.querySelectorAll('.reveal');
    const observer = new IntersectionObserver(entries => {
      entries.forEach((e, i) => {
        if (e.isIntersecting) {
          setTimeout(() => e.target.classList.add('visible'), i * 80);
          observer.unobserve(e.target);
        }
      });
    }, { threshold: 0.12 });
    revealEls.forEach(el => observer.observe(el));

    // ── Waitlist counter (local, bumps on each signup) ──
    let count = parseInt(localStorage.getItem('gg_waitlist_count') || '847');
    document.getElementById('waitlist-num').textContent = count.toLocaleString();

    // ── Signup handler ──
    window.handleSignup = function() {
      const name   = document.getElementById('user-name').value.trim();
      const email  = document.getElementById('user-email').value.trim();
      const goal   = document.getElementById('user-goal').value;
      const btn    = document.getElementById('submit-btn');

      if (!name || !email) {
        shake(btn);
        return;
      }
      if (!email.includes('@') || !email.includes('.')) {
        shake(btn);
        return;
      }

      btn.textContent = 'Joining…';
      btn.classList.add('loading');

      const templateParams = {
        to_name:   name,
        to_email:  email,
        user_goal: goal || 'Not specified',
        reply_to:  'info@gourmetgains.co.uk',
      };

      emailjs.send(EMAILJS_SERVICE_ID, EMAILJS_TEMPLATE_ID, templateParams)
        .then(() => {
          showSuccess(name, email);
        })
        .catch(() => {
          // Fallback: still show success to user even if email fails
          // (you can log this server-side in production)
          showSuccess(name, email);
        });
    };

    function showSuccess(name) {
      count++;
      localStorage.setItem('gg_waitlist_count', count);
      document.getElementById('waitlist-num').textContent = count.toLocaleString();
      document.getElementById('success-pos').textContent = `You're #${count.toLocaleString()} on the waitlist`;
      document.getElementById('form-state').style.display = 'none';
      const s = document.getElementById('success-state');
      s.style.display = 'flex';
    }

    function shake(el) {
      el.style.animation = 'none';
      el.offsetHeight; // reflow
      el.style.animation = 'shake 0.4s ease';
      el.textContent = 'Please fill in your name & email';
      setTimeout(() => { el.textContent = 'Join the Waitlist — It\'s Free'; }, 2000);
    }
  })();
</script>
