  display: inline-block;
  margin-top: 16px;
  background: rgba(201,168,76,0.15);
  border: 1px solid rgba(201,168,76,0.25);
  color: var(--gold);
  font-size: 12px;
  font-weight: 600;
  letter-spacing: 0.06em;
  padding: 6px 14px;
  border-radius: 100px;
}

